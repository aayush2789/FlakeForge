# FlakeForge Inference - Environment Variables Template
# Copy this file to .env and fill in your values

# ============================================================================
# NVIDIA API Configuration (REQUIRED)
# ============================================================================
NVIDIA_API_KEY=your-nvidia-api-key-here
# Fallback if NVIDIA_API_KEY not set
OPENAI_API_KEY=

# ============================================================================
# Models (Small models recommended for quick testing)
# ============================================================================

# Analyzer & Fixer models - choose a small, fast model:
# Options:
#   - nvidia/llama-3.1-nemotron-70b-instruct (recommended for quality)
#   - meta-llama/llama-3-8b-instruct (fastest)
#   - mistralai/mixtral-8x7b-instruct-v0.1
MODEL_NAME=nvidia/llama-3.1-nemotron-70b-instruct

# Judge model - Minimax for scoring as discussed
JUDGE_MODEL=minimaxai/minimax-m2.7

# ============================================================================
# API Configuration
# ============================================================================
API_BASE_URL=https://integrate.api.nvidia.com/v1

# ============================================================================
# Environment Setup
# ============================================================================

# API base URL for remote episode runs (FlakeForge server / OpenAI-compatible HTTP)
ENV_BASE_URL=http://localhost:8000

# ============================================================================
# Default episode targets (web UI + /api/episode/run defaults)
# ============================================================================
FF_REPO_PATH=test_repos/timing_race_minimal
FF_TEST_ID=tests/test_flaky.py::test_fetch_should_complete
FF_NUM_RUNS=10

# ============================================================================
# Web UI copy (optional — overrides defaults from /api/ui/bootstrap)
# ============================================================================
# FF_UI_TEAM_NAME=Team Name
# FF_UI_HERO_EYEBROW=Custom tagline
# FF_UI_HERO_TITLE=FlakeForge
# FF_UI_HERO_SUBTITLE=Custom description
# FF_UI_FOOTER=Custom footer line

# ============================================================================
# Inference Configuration
# ============================================================================

# Maximum steps per episode (lower = faster testing)
INFERENCE_MAX_STEPS=5

# Model parameters
TEMPERATURE=0.1
MAX_TOKENS=900
REQUEST_TIMEOUT_S=45

# ============================================================================
# Logging & Output
# ============================================================================
# (Outputs go to ./outputs/ by default)

# ============================================================================
# QUICK START CHECKLIST
# ============================================================================
# 1. Fill in NVIDIA_API_KEY above
# 2. Save this file as .env in your working directory
# 3. Run: python test_runner.py
#
# For full inference with server:
# Terminal 1: cd ../.. && uv run server --port 8000
# Terminal 2: export ENV_BASE_URL=http://localhost:8000 && python test_runner.py --run-inference
